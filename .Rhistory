library(rDataRecon)
source("tests/testthat/test-sdtm.R")
base_df <- data.frame(
id   = 1:5,
age  = c(25L, 30L, 35L, 40L, 45L),
name = c("Alice", "Bob", "Carol", "Dave", "Eve"),
stringsAsFactors = FALSE
)
comp_df <- data.frame(
id   = 1:5,
age  = c(25L, 31L, 35L, 40L, 45L),
name = c("Alice", "bob", "Carol", "Dave", "Eve"),
stringsAsFactors = FALSE
)
result <- recon(base_df, comp_df, id = "id")
library(rDataRecon)
result <- recon(base_df, comp_df, id = "id")
result
